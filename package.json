{
  "name": "midad",
  "version": "1.0.0",
  "description": "Midad",
  "main": "backend/src/server.js",
  "type": "module",
  "scripts": {
    "server": "nodemon backend/src/server.js",
    "client": "npm --prefix frontend run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "start": "node backend/src/server.js",
    "build": "npm install && npm install --prefix frontend && npm run build --prefix frontend"
  },
  "dependencies": {
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "mongoose": "^9.6.2"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Juwayyed/Midad.git"
  },
  "bugs": {
    "url": "https://github.com/Juwayyed/Midad/issues"
  },
  "homepage": "https://github.com/Juwayyed/Midad#readme",
